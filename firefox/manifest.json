{
  "manifest_version": 2,
  "name": "LinkedIn Unbiaser",
  "version": "0.1",
  "description": "Makes your experience on LinkedIn a bit less biased.",
  "content_scripts": [
    {
      "matches": ["*://www.linkedin.com/*"],
      "css": ["unbiaser.css"],
      "run_at": "document_start"
    }
  ]
}

